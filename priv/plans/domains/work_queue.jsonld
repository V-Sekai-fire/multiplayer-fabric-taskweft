{
  "@context": {
    "khr": "https://registry.khronos.org/glTF/extensions/2.0/KHR_interactivity/",
    "domain": "khr:planning/domain/"
  },
  "@type": "domain:Definition",
  "name": "work_queue",
  "version": "4.0",
  "description": "multiplayer-fabric work queue (2026-04-28). Actions are deterministic. Commands (actions sent to the real world) are probabilistic — MCExecutor models failure with a per-run failure_rate. Method alternatives encode genuinely different approaches for complex items, not duration variants. Single entity (ifire), one Saturday per week.",

  "scope": "Shared MMOG fabric beneath multiplayer-fabric-xr-dev (VR) and multiplayer-fabric-rpg (RPG): engine assembly, zone networking, and interest management.",

  "win_condition": "All four TUI scenarios (concert, chokepoint, convoy, ragdoll) complete with 16 mires visible in zone_console, 20 Hz tick maintained throughout, and zero entity loss — all in a terminal. No VR headset, no GPU, no Godot window required.",

  "stack": {
    "engine_assembly":    "multiplayer-fabric-merge — gitassembly → multiplayer-fabric branch",
    "godot_fork":         "multiplayer-fabric-godot — branch multiplayer-fabric",
    "build_system":       "multiplayer-fabric-build — SCons, Justfile",
    "zone_server":        "multiplayer-fabric-humanoid-project — headless Godot running mire.tscn; 20 Hz constant-work loop; 100-byte entity snapshots",
    "zone_registry":      "multiplayer-fabric-zone-backend — Elixir/Phoenix, WebTransport/HTTP3",
    "interest_management":"multiplayer-fabric-predictive-bvh — Lean-verified BVH",
    "bots":               "taskweft/picoquic — C++20, HTN planner, ~15 MB each; not full Godot processes",
    "observer":           "multiplayer-fabric-zone-console — ratatui TUI, WebTransport observer"
  },

  "resource_budget": {
    "hardware": "M2 Pro, 12 cores, 32 GB",
    "zone_backend": "1 core",
    "zone_server": "1 core",
    "os_headroom": "1 core",
    "bots_16x": "~240 MB RAM, 9 cores shared"
  },

  "pass_conditions": {
    "engine_boot":    "godot --headless --quit-after 300 exits 0; no SCRIPT ERROR",
    "vrm_visible":    "VRM character loads in mire.tscn; MToon shader and humanoid skeleton work",
    "character_steps":"Basic rigid-body plane collision and input routing functional",
    "zone_connect":   "WebTransport HTTP/3 handshake succeeds between client and zone-backend",
    "all_mires":      "Zone server logs 16 registered players in each scenario",
    "entity_slots":   "896 occupied (16 × 56); zone never exceeds 1800",
    "tick_rate":      "20 Hz held; tick=50ms in TUI status bar for all 4 scenarios",
    "clean_shutdown": "FabricSnapshot written after each scenario; positions recoverable"
  },

  "scenarios": {
    "concert": {
      "lean": "separatedConcertFits / naiveConcertFits — Interest/AuthorityInterest.lean",
      "description": "All 16 bots converge to the same zone area. Local players fill authority budget; remote players fill interest/replica budget. Proves lo + re ≤ (cap − headroom) + InterestCapacity.",
      "pass": "separatedConcertFits 16 0 1800 400 holds; interest-set snapshot = 896 slots"
    },
    "chokepoint": {
      "lean": "currentFunnelPeakVUmTick = 60 m/s, c7_current_funnel_exceeds_cap, c7_funnel_mitigation_ge — Spatial/ScaleContradictions.lean",
      "description": "Bots rush through a narrow corridor, reaching speeds above vMaxPhysical (10 m/s) due to crowd pressure. Zone server registers funnel segment with per-segment velocity cap.",
      "pass": "No entity exits BVH ghost bound; funnel velocity override logged; no SCRIPT ERROR"
    },
    "convoy": {
      "lean": "wpPeriodMin / migration_completes_before_phase_flip — Protocol/WaypointBound.lean",
      "description": "Mover entity leads cabin bots on a periodic route crossing the zone boundary. One full cycle = 2 × wpPeriodMin. STAGING migration completes before phase reversal.",
      "pass": "All cabin bots complete ≥ 2 zone crossings; wpPeriodValid holds; no cabin lost during STAGING"
    },
    "ragdoll": {
      "lean": "g13_vTrue = 15 m/s, aHalfMinForearm (C1/C2) — Spatial/ScaleContradictions.lean",
      "description": "Bots collide head-on at g13_vTrue = 15 m/s (above vMaxPhysical). C1 clamps to vMaxPhysical; C2 uses aHalfMinForearm in ghost bound expansion.",
      "pass": "Server clamps impulse velocities (C1); ghost bound uses aHalfMinForearm (C2); tick p99 ≤ 2× baseline"
    }
  },
  "enums": {
    "phase":    {"unstarted": 0, "stub": 1, "green": 2, "done": 3},
    "approach": {"direct": 0, "prototype_first": 1}
  },
  "variables": [
    {
      "name": "phase",
      "description": "Phase of each item. 3 = done.",
      "init": {
        "lean4_infra":        3, "zone_arch":          3, "monorepo_split":     3,
        "taskweft":           3, "operator_camera":    3, "reduce_merge":       3,
        "rebac_enforcement":  3, "domain_jsonld":      3, "sqlite_journal":     3,
        "zone_registry":      3, "build_cache":        3, "operator_overlay":   3,
        "asset_delivery":     3, "baker_lifecycle":    3, "rectgtn_behavior":   3,
        "zone_border_handoff":3,
        "openxr_simulator":   0, "isolated_submodule": 0, "vr_interaction":     0,
        "zone_manifest":      0, "concert_archetype":  0, "ragdoll_archetype":  0,
        "pcvr_player":        0, "sandbox_rebac":      0, "artifactsmmog_bot":  0,
        "convoy_chokepoint":  0, "jellyfish_demo":     0, "headless_observer":  0,
        "headless_matrix":    0, "otel_tracing":       0, "turboquant_llm":     0,
        "gepa_cycle":         0
      }
    },
    {
      "name": "approach",
      "description": "Chosen implementation approach for complex items. Set by method selection.",
      "init": {
        "vr_interaction":   0,
        "sandbox_rebac":    0,
        "turboquant_llm":   0,
        "convoy_chokepoint":0,
        "gepa_cycle":       0
      }
    }
  ],
  "actions": {
    "a_stub": {
      "description": "Deterministic: define interfaces and failing tests. Command to real world: developer writes stub. P7D = one Saturday.",
      "duration": "P7D",
      "params": ["item", "entity"],
      "body": [
        {"check": "/phase/{item}", "eq": 0},
        {"set":   "/phase/{item}", "value": 1}
      ]
    },
    "a_green": {
      "description": "Deterministic: implement to pass tests and write Lean proof. P14D = two Saturdays.",
      "duration": "P14D",
      "params": ["item", "entity"],
      "body": [
        {"check": "/phase/{item}", "eq": 1},
        {"set":   "/phase/{item}", "value": 2}
      ]
    },
    "a_refactor": {
      "description": "Deterministic: clean up, tune, document. P7D = one Saturday.",
      "duration": "P7D",
      "params": ["item", "entity"],
      "body": [
        {"check": "/phase/{item}", "eq": 2},
        {"set":   "/phase/{item}", "value": 3}
      ]
    },
    "a_set_prototype_first": {
      "description": "Deterministic: record that this item uses the prototype-first approach before committing to full implementation.",
      "duration": "PT0S",
      "params": ["item"],
      "body": [
        {"set": "/approach/{item}", "value": 1}
      ]
    }
  },
  "methods": {
    "xr_dev_track":   {"alternatives": [{"name": "run", "subtasks": [["complete_openxr_simulator"], ["complete_vr_interaction"]]}]},
    "mmog_dev_track": {"alternatives": [{"name": "run", "subtasks": [["complete_pcvr_player"]]}]},
    "demo_dev_track": {"alternatives": [{"name": "run", "subtasks": [["complete_zone_manifest"], ["complete_sandbox_rebac"], ["complete_jellyfish_demo"]]}]},
    "ci_dev_track":   {"alternatives": [{"name": "run", "subtasks": [["complete_isolated_submodule"], ["complete_headless_observer"], ["complete_headless_matrix"]]}]},
    "rpg_dev_track":  {"alternatives": [{"name": "run", "subtasks": [["complete_turboquant_llm"], ["complete_artifactsmmog_bot"], ["complete_gepa_cycle"]]}]},
    "arch_dev_track": {"alternatives": [{"name": "run", "subtasks": [["complete_concert_archetype"], ["complete_ragdoll_archetype"], ["complete_convoy_chokepoint"], ["complete_otel_tracing"]]}]},

    "complete_openxr_simulator": {
      "description": "C=5. One approach: configure + activate. MCExecutor failure_rate models simulator not found / version mismatch.",
      "alternatives": [
        {"name": "done",   "check": [{"pointer": "/phase/openxr_simulator", "eq": 3}], "subtasks": []},
        {"name": "direct", "subtasks": [["a_stub","openxr_simulator","ifire"], ["a_green","openxr_simulator","ifire"], ["a_refactor","openxr_simulator","ifire"]]}
      ]
    },
    "complete_vr_interaction": {
      "description": "C=4 (3 open blockers). Two approaches: direct integration OR prototype lasso-only first then add canvas_plane. MCExecutor failure_rate models test row failures.",
      "alternatives": [
        {"name": "done",             "check": [{"pointer": "/phase/vr_interaction", "eq": 3}], "subtasks": []},
        {"name": "direct",           "subtasks": [["complete_openxr_simulator"], ["a_stub","vr_interaction","ifire"], ["a_green","vr_interaction","ifire"], ["a_refactor","vr_interaction","ifire"]]},
        {"name": "prototype_first",  "subtasks": [["complete_openxr_simulator"], ["a_set_prototype_first","vr_interaction"], ["a_stub","vr_interaction","ifire"], ["a_green","vr_interaction","ifire"], ["a_green","vr_interaction","ifire"], ["a_refactor","vr_interaction","ifire"]]}
      ]
    },
    "complete_pcvr_player": {
      "description": "C=6. One approach: CH_PLAYER write path + OpenXR. MCExecutor failure_rate models headset pairing failures.",
      "alternatives": [
        {"name": "done",   "check": [{"pointer": "/phase/pcvr_player", "eq": 3}], "subtasks": []},
        {"name": "direct", "subtasks": [["complete_openxr_simulator"], ["a_stub","pcvr_player","ifire"], ["a_green","pcvr_player","ifire"], ["a_refactor","pcvr_player","ifire"]]}
      ]
    },
    "complete_zone_manifest": {
      "description": "C=6. One approach: JSON schema + endpoint. MCExecutor failure_rate models schema validation failures.",
      "alternatives": [
        {"name": "done",   "check": [{"pointer": "/phase/zone_manifest", "eq": 3}], "subtasks": []},
        {"name": "direct", "subtasks": [["a_stub","zone_manifest","ifire"], ["a_green","zone_manifest","ifire"], ["a_refactor","zone_manifest","ifire"]]}
      ]
    },
    "complete_sandbox_rebac": {
      "description": "C=4. Two approaches: full RISC-V sandbox OR stub capability checks first then add sandbox. MCExecutor failure_rate models NIF ABI shim failures.",
      "alternatives": [
        {"name": "done",            "check": [{"pointer": "/phase/sandbox_rebac", "eq": 3}], "subtasks": []},
        {"name": "direct",          "subtasks": [["a_stub","sandbox_rebac","ifire"], ["a_green","sandbox_rebac","ifire"], ["a_refactor","sandbox_rebac","ifire"]]},
        {"name": "capability_first","subtasks": [["a_set_prototype_first","sandbox_rebac"], ["a_stub","sandbox_rebac","ifire"], ["a_green","sandbox_rebac","ifire"], ["a_green","sandbox_rebac","ifire"], ["a_refactor","sandbox_rebac","ifire"]]}
      ]
    },
    "complete_jellyfish_demo": {
      "description": "C=7 (wiring proven components). One approach: wire all deps then integrate. MCExecutor failure_rate models pass-condition failures.",
      "alternatives": [
        {"name": "done",   "check": [{"pointer": "/phase/jellyfish_demo", "eq": 3}], "subtasks": []},
        {"name": "direct", "subtasks": [["complete_vr_interaction"], ["complete_pcvr_player"], ["complete_sandbox_rebac"], ["a_stub","jellyfish_demo","ifire"], ["a_green","jellyfish_demo","ifire"], ["a_refactor","jellyfish_demo","ifire"]]}
      ]
    },
    "complete_isolated_submodule": {
      "description": "C=6. One approach: add godot-* submodule checkouts to build repo.",
      "alternatives": [
        {"name": "done",   "check": [{"pointer": "/phase/isolated_submodule", "eq": 3}], "subtasks": []},
        {"name": "direct", "subtasks": [["a_stub","isolated_submodule","ifire"], ["a_green","isolated_submodule","ifire"], ["a_refactor","isolated_submodule","ifire"]]}
      ]
    },
    "complete_headless_observer": {
      "description": "C=8 (GDScript reusing existing peer). One approach: extend existing headless_log_observer.gd.",
      "alternatives": [
        {"name": "done",   "check": [{"pointer": "/phase/headless_observer", "eq": 3}], "subtasks": []},
        {"name": "direct", "subtasks": [["complete_isolated_submodule"], ["a_stub","headless_observer","ifire"], ["a_green","headless_observer","ifire"], ["a_refactor","headless_observer","ifire"]]}
      ]
    },
    "complete_headless_matrix": {
      "description": "C=7 (shell-only orchestration). One approach: run_matrix.sh driving GO+GP roles.",
      "alternatives": [
        {"name": "done",   "check": [{"pointer": "/phase/headless_matrix", "eq": 3}], "subtasks": []},
        {"name": "direct", "subtasks": [["complete_headless_observer"], ["a_stub","headless_matrix","ifire"], ["a_green","headless_matrix","ifire"], ["a_refactor","headless_matrix","ifire"]]}
      ]
    },
    "complete_turboquant_llm": {
      "description": "C=5 (Elixir NIF risk). Two approaches: compile against turboquant-godot OR use pre-built .so. MCExecutor failure_rate models NIF compilation failures.",
      "alternatives": [
        {"name": "done",       "check": [{"pointer": "/phase/turboquant_llm", "eq": 3}], "subtasks": []},
        {"name": "compile",    "subtasks": [["a_stub","turboquant_llm","ifire"], ["a_green","turboquant_llm","ifire"], ["a_refactor","turboquant_llm","ifire"]]},
        {"name": "prebuilt_so","subtasks": [["a_set_prototype_first","turboquant_llm"], ["a_stub","turboquant_llm","ifire"], ["a_green","turboquant_llm","ifire"], ["a_refactor","turboquant_llm","ifire"]]}
      ]
    },
    "complete_artifactsmmog_bot": {
      "description": "C=5. One approach: REST API + HTN plan + execute.",
      "alternatives": [
        {"name": "done",   "check": [{"pointer": "/phase/artifactsmmog_bot", "eq": 3}], "subtasks": []},
        {"name": "direct", "subtasks": [["a_stub","artifactsmmog_bot","ifire"], ["a_green","artifactsmmog_bot","ifire"], ["a_refactor","artifactsmmog_bot","ifire"]]}
      ]
    },
    "complete_gepa_cycle": {
      "description": "C=3 (research-grade). Two approaches: full ASI+Pareto OR start with simple critique loop then add Pareto. MCExecutor failure_rate models LLM critique quality failures.",
      "alternatives": [
        {"name": "done",          "check": [{"pointer": "/phase/gepa_cycle", "eq": 3}], "subtasks": []},
        {"name": "direct",        "subtasks": [["complete_turboquant_llm"], ["complete_artifactsmmog_bot"], ["a_stub","gepa_cycle","ifire"], ["a_green","gepa_cycle","ifire"], ["a_refactor","gepa_cycle","ifire"]]},
        {"name": "critique_first","subtasks": [["complete_turboquant_llm"], ["complete_artifactsmmog_bot"], ["a_set_prototype_first","gepa_cycle"], ["a_stub","gepa_cycle","ifire"], ["a_green","gepa_cycle","ifire"], ["a_green","gepa_cycle","ifire"], ["a_refactor","gepa_cycle","ifire"]]}
      ]
    },
    "complete_concert_archetype": {
      "description": "C=5. One approach: wire separatedConcertFits theorem to zone server load test.",
      "alternatives": [
        {"name": "done",   "check": [{"pointer": "/phase/concert_archetype", "eq": 3}], "subtasks": []},
        {"name": "direct", "subtasks": [["a_stub","concert_archetype","ifire"], ["a_green","concert_archetype","ifire"], ["a_refactor","concert_archetype","ifire"]]}
      ]
    },
    "complete_ragdoll_archetype": {
      "description": "C=5. One approach: wire g13_vTrue / aHalfMinForearm to zone server tick test.",
      "alternatives": [
        {"name": "done",   "check": [{"pointer": "/phase/ragdoll_archetype", "eq": 3}], "subtasks": []},
        {"name": "direct", "subtasks": [["a_stub","ragdoll_archetype","ifire"], ["a_green","ragdoll_archetype","ifire"], ["a_refactor","ragdoll_archetype","ifire"]]}
      ]
    },
    "complete_convoy_chokepoint": {
      "description": "C=4. Two approaches: implement both convoy+chokepoint together OR convoy first then chokepoint. Both require zone_border_handoff done.",
      "alternatives": [
        {"name": "done",          "check": [{"pointer": "/phase/convoy_chokepoint", "eq": 3}], "subtasks": []},
        {"name": "together",      "subtasks": [["a_stub","convoy_chokepoint","ifire"], ["a_green","convoy_chokepoint","ifire"], ["a_refactor","convoy_chokepoint","ifire"]]},
        {"name": "convoy_first",  "subtasks": [["a_set_prototype_first","convoy_chokepoint"], ["a_stub","convoy_chokepoint","ifire"], ["a_green","convoy_chokepoint","ifire"], ["a_green","convoy_chokepoint","ifire"], ["a_refactor","convoy_chokepoint","ifire"]]}
      ]
    },
    "complete_otel_tracing": {
      "description": "C=6. One approach: stub spans at zone connect and packet parse.",
      "alternatives": [
        {"name": "done",   "check": [{"pointer": "/phase/otel_tracing", "eq": 3}], "subtasks": []},
        {"name": "direct", "subtasks": [["a_stub","otel_tracing","ifire"], ["a_green","otel_tracing","ifire"], ["a_refactor","otel_tracing","ifire"]]}
      ]
    }
  },
  "tasks": [
    ["xr_dev_track"],
    ["mmog_dev_track"],
    ["demo_dev_track"],
    ["ci_dev_track"],
    ["rpg_dev_track"],
    ["arch_dev_track"]
  ]
}
